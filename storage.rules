rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function listPath(listId) {
      return /databases/(default)/documents/lists/$(listId);
    }

    function entitlementPath(userId) {
      return /databases/(default)/documents/accountEntitlements/$(userId);
    }

    function listExists(listId) {
      return firestore.exists(listPath(listId));
    }

    function entitlementExists(userId) {
      return firestore.exists(entitlementPath(userId));
    }

    function listData(listId) {
      return firestore.get(listPath(listId)).data;
    }

    function entitlementData(userId) {
      return firestore.get(entitlementPath(userId)).data;
    }

    function isListOwner(listId) {
      return isSignedIn()
        && listExists(listId)
        && listData(listId).ownerId == request.auth.uid;
    }

    function hasActiveComplimentaryEntitlementForUser(userId) {
      return userId is string
        && userId.size() > 0
        && entitlementExists(userId)
        && entitlementData(userId).tier == 'complimentary_unlimited'
        && entitlementData(userId).status == 'active'
        && (
          !entitlementData(userId).keys().hasAny(['expiresAt'])
          || entitlementData(userId).expiresAt == null
          || (
            entitlementData(userId).expiresAt is timestamp
            && entitlementData(userId).expiresAt > request.time
          )
        );
    }

    function hasActiveListAccess(listId) {
      return listExists(listId)
        && (
          hasActiveComplimentaryEntitlementForUser(listData(listId).ownerId)
          || (
            (
              listData(listId).paidAccessEndsAt is timestamp
              && listData(listId).paidAccessEndsAt > request.time
            )
            || (
              listData(listId).paidAccessEndsAt == null
              && listData(listId).trialEndsAt is timestamp
              && listData(listId).trialEndsAt > request.time
            )
          )
        );
    }

    function hasPublishedListAccess(listId) {
      return listExists(listId)
        && (
          hasActiveComplimentaryEntitlementForUser(listData(listId).ownerId)
          || (
            listData(listId).paidAccessEndsAt is timestamp
            && listData(listId).paidAccessEndsAt > request.time
          )
        );
    }

    function isListPublic(listId) {
      return listExists(listId)
        && listData(listId).visibility == 'public'
        && hasPublishedListAccess(listId);
    }

    function isSupportedMediaType() {
      return request.resource != null
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('audio/.*')
        );
    }

    function isWithinSizeLimit(limitMb) {
      return request.resource != null
        && request.resource.size <= (limitMb * 1024 * 1024);
    }

    function isWithinUploadLimit() {
      return request.resource != null
        && (
          (
            request.resource.contentType.matches('video/.*')
            && isWithinSizeLimit(250)
          )
          || (
            !request.resource.contentType.matches('video/.*')
            && isWithinSizeLimit(30)
          )
        );
    }

    // Private user-level assets.
    match /users/{userId}/{allPaths=**} {
      allow read: if isUser(userId);
      allow write: if isUser(userId)
        && isSupportedMediaType()
        && isWithinUploadLimit();
    }

    // List assets. Ownership is validated against Firestore list document.
    match /lists/{listId}/{allPaths=**} {
      allow read: if isListOwner(listId) || isListPublic(listId);
      allow write: if isListOwner(listId)
        && isSupportedMediaType()
        && isWithinUploadLimit();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
