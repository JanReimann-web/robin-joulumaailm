rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function listPath(listId) {
      return /databases/$(database)/documents/lists/$(listId);
    }

    function entitlementPath(userId) {
      return /databases/$(database)/documents/accountEntitlements/$(userId);
    }

    function listExists(listId) {
      return exists(listPath(listId));
    }

    function entitlementExists(userId) {
      return exists(entitlementPath(userId));
    }

    function listData(listId) {
      return get(listPath(listId)).data;
    }

    function entitlementData(userId) {
      return get(entitlementPath(userId)).data;
    }

    function isListOwner(listId) {
      return isSignedIn()
        && listExists(listId)
        && listData(listId).ownerId == request.auth.uid;
    }

    function hasActiveComplimentaryEntitlementForUser(userId) {
      return userId is string
        && userId.size() > 0
        && entitlementExists(userId)
        && entitlementData(userId).tier == 'complimentary_unlimited'
        && entitlementData(userId).status == 'active'
        && (
          !entitlementData(userId).keys().hasAny(['expiresAt'])
          || entitlementData(userId).expiresAt == null
          || (
            entitlementData(userId).expiresAt is timestamp
            && entitlementData(userId).expiresAt > request.time
          )
        );
    }

    function hasActiveListAccessData(data) {
      return (
        hasActiveComplimentaryEntitlementForUser(data.ownerId)
        || (
          (
            data.paidAccessEndsAt is timestamp
            && data.paidAccessEndsAt > request.time
          )
          || (
            data.paidAccessEndsAt == null
            && data.trialEndsAt is timestamp
            && data.trialEndsAt > request.time
          )
        )
      );
    }

    function hasPublishedListAccessData(data) {
      return hasActiveComplimentaryEntitlementForUser(data.ownerId)
        || (
          data.paidAccessEndsAt is timestamp
          && data.paidAccessEndsAt > request.time
        );
    }

    function hasActiveListAccess(listId) {
      return listExists(listId)
        && hasActiveListAccessData(listData(listId));
    }

    function hasPublishedListAccess(listId) {
      return listExists(listId)
        && hasPublishedListAccessData(listData(listId));
    }

    function isListPublic(listId) {
      return listExists(listId)
        && listData(listId).visibility == 'public'
        && hasPublishedListAccess(listId);
    }

    function isCurrentListOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isCurrentListPublicWithAccess() {
      return resource.data.visibility == 'public'
        && hasPublishedListAccessData(resource.data);
    }

    function isStringOrNull(value) {
      return value is string || value == null;
    }

    function hasUnchangedOptionalBillingPlanId() {
      return (
        (
          !resource.data.keys().hasAny(['billingPlanId'])
          && !request.resource.data.keys().hasAny(['billingPlanId'])
        )
        || (
          resource.data.keys().hasAny(['billingPlanId'])
          && request.resource.data.keys().hasAny(['billingPlanId'])
          && request.resource.data.billingPlanId == resource.data.billingPlanId
        )
      );
    }

    function isNumberOrNull(value) {
      return value is int || value is float || value == null;
    }

    function hasOptionalIntroFields(data) {
      return (
        (
          !data.keys().hasAny(['introTitle'])
          || isStringOrNull(data.introTitle)
        )
        && (
          !data.keys().hasAny(['introBody'])
          || isStringOrNull(data.introBody)
        )
        && (
          !data.keys().hasAny(['introEventDate'])
          || isStringOrNull(data.introEventDate)
        )
        && (
          !data.keys().hasAny(['introEventLocation'])
          || isStringOrNull(data.introEventLocation)
        )
        && (
          !data.keys().hasAny(['introMediaUrl'])
          || isStringOrNull(data.introMediaUrl)
        )
        && (
          !data.keys().hasAny(['introMediaPath'])
          || isStringOrNull(data.introMediaPath)
        )
        && (
          !data.keys().hasAny(['introMediaType'])
          || isStringOrNull(data.introMediaType)
        )
        && (
          !data.keys().hasAny(['introMediaSizeBytes'])
          || isNumberOrNull(data.introMediaSizeBytes)
        )
        && (
          !data.keys().hasAny(['introMediaDurationSeconds'])
          || isNumberOrNull(data.introMediaDurationSeconds)
        )
      );
    }

    function isKnownEventType(value) {
      return (
        value == 'wedding'
        || value == 'birthday'
        || value == 'kidsBirthday'
        || value == 'babyShower'
        || value == 'graduation'
        || value == 'housewarming'
        || value == 'christmas'
      );
    }

    function isDefaultTemplateId(value) {
      return (
        value == 'classic'
        || value == 'modern'
        || value == 'minimal'
        || value == 'playful'
      );
    }

    function isKidsBirthdayTemplateId(value) {
      return (
        value == 'kidsBoyTinyPilot'
        || value == 'kidsBoyDinoRanger'
        || value == 'kidsBoyGalaxyRacer'
        || value == 'kidsGirlTinyBloom'
        || value == 'kidsGirlFairyGarden'
        || value == 'kidsGirlStarlightPop'
      );
    }

    function hasValidTemplateForEvent(eventType, templateId) {
      return isKnownEventType(eventType)
        && (
          (eventType == 'kidsBirthday' && isKidsBirthdayTemplateId(templateId))
          || (eventType != 'kidsBirthday' && isDefaultTemplateId(templateId))
        );
    }

    function isValidListCreate() {
      return request.resource.data.keys().hasOnly([
          'ownerId',
          'title',
          'slug',
          'eventType',
          'templateId',
          'visibility',
          'status',
          'billingModel',
          'billingPlanId',
          'trialEndsAt',
          'paidAccessEndsAt',
          'purgeAt',
          'introTitle',
          'introBody',
          'introEventDate',
          'introEventLocation',
          'introMediaUrl',
          'introMediaPath',
          'introMediaType',
          'introMediaSizeBytes',
          'introMediaDurationSeconds',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.slug is string
        && request.resource.data.eventType is string
        && isKnownEventType(request.resource.data.eventType)
        && request.resource.data.templateId is string
        && hasValidTemplateForEvent(
          request.resource.data.eventType,
          request.resource.data.templateId
        )
        && (
          request.resource.data.visibility == 'public'
          || request.resource.data.visibility == 'public_password'
          || request.resource.data.visibility == 'private'
        )
        && request.resource.data.status == 'draft'
        && request.resource.data.billingModel == 'one_time_90d'
        && (
          !request.resource.data.keys().hasAny(['billingPlanId'])
          || request.resource.data.billingPlanId == null
        )
        && request.resource.data.trialEndsAt is timestamp
        && request.resource.data.paidAccessEndsAt == null
        && request.resource.data.purgeAt is timestamp
        && request.resource.data.purgeAt == request.resource.data.trialEndsAt
        && hasOptionalIntroFields(request.resource.data)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidPublicItemReservationUpdate() {
      return resource.data.status == 'available'
        && request.resource.data.status == 'reserved'
        && request.resource.data.listId == resource.data.listId
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.link == resource.data.link
        && request.resource.data.createdAt == resource.data.createdAt
        && isStringOrNull(request.resource.data.reservedByName)
        && isStringOrNull(request.resource.data.reservedMessage)
        && request.resource.data.reservedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data
          .diff(resource.data)
          .changedKeys()
          .hasOnly([
            'status',
            'reservedByName',
            'reservedMessage',
            'reservedAt',
            'updatedAt',
          ]);
    }

    function isValidPublicReservationCreate() {
      return request.resource.data.keys().hasOnly([
          'itemId',
          'guestName',
          'guestMessage',
          'status',
          'createdAt',
        ])
        && request.resource.data.itemId is string
        && isStringOrNull(request.resource.data.guestName)
        && isStringOrNull(request.resource.data.guestMessage)
        && request.resource.data.status == 'active'
        && request.resource.data.createdAt is timestamp;
    }

    function isValidStoryCreate(listId) {
      return request.resource.data.keys().hasOnly([
          'listId',
          'order',
          'title',
          'body',
          'mediaUrl',
          'mediaPath',
          'mediaType',
          'mediaSizeBytes',
          'mediaDurationSeconds',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.listId == listId
        && request.resource.data.order is int
        && request.resource.data.title is string
        && request.resource.data.body is string
        && isStringOrNull(request.resource.data.mediaUrl)
        && isStringOrNull(request.resource.data.mediaPath)
        && isStringOrNull(request.resource.data.mediaType)
        && (
          !request.resource.data.keys().hasAny(['mediaSizeBytes'])
          || isNumberOrNull(request.resource.data.mediaSizeBytes)
        )
        && (
          !request.resource.data.keys().hasAny(['mediaDurationSeconds'])
          || isNumberOrNull(request.resource.data.mediaDurationSeconds)
        )
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidWheelEntryCreate(listId) {
      return request.resource.data.keys().hasOnly([
          'listId',
          'order',
          'question',
          'answerText',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.listId == listId
        && request.resource.data.order is int
        && request.resource.data.question is string
        && request.resource.data.answerText is string
        && request.resource.data.question.size() > 0
        && request.resource.data.answerText.size() > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidListOwnerUpdate() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.slug == resource.data.slug
        && request.resource.data.billingModel == resource.data.billingModel
        && hasUnchangedOptionalBillingPlanId()
        && request.resource.data.trialEndsAt == resource.data.trialEndsAt
        && request.resource.data.paidAccessEndsAt == resource.data.paidAccessEndsAt
        && request.resource.data.purgeAt == resource.data.purgeAt
        && request.resource.data.eventType is string
        && request.resource.data.templateId is string
        && hasValidTemplateForEvent(
          request.resource.data.eventType,
          request.resource.data.templateId
        )
        && (
          request.resource.data.visibility == 'public'
          || request.resource.data.visibility == 'public_password'
          || request.resource.data.visibility == 'private'
        )
        && hasOptionalIntroFields(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data
          .diff(resource.data)
          .changedKeys()
          .hasOnly([
            'title',
            'eventType',
            'templateId',
            'visibility',
            'introTitle',
            'introBody',
            'introEventDate',
            'introEventLocation',
            'introMediaUrl',
            'introMediaPath',
            'introMediaType',
            'introMediaSizeBytes',
            'introMediaDurationSeconds',
            'status',
            'updatedAt',
          ]);
    }

    match /users/{userId} {
      allow create: if isUser(userId);
      allow read, update, delete: if isUser(userId);
    }

    match /accountEntitlements/{userId} {
      allow read: if isUser(userId);
      allow write: if false;
    }

    match /lists/{listId} {
      allow create: if isSignedIn() && isValidListCreate();
      allow read: if isCurrentListOwner() || isCurrentListPublicWithAccess();
      allow update: if isListOwner(listId) && isValidListOwnerUpdate();
      allow delete: if isListOwner(listId);
    }

    match /lists/{listId}/items/{itemId} {
      allow create: if isListOwner(listId)
        && request.resource.data.listId == listId;
      allow read: if isListOwner(listId) || isListPublic(listId);
      allow update: if isListOwner(listId)
        || (isListPublic(listId) && isValidPublicItemReservationUpdate());
      allow delete: if isListOwner(listId);
    }

    match /lists/{listId}/reservations/{reservationId} {
      allow create: if isListOwner(listId)
        || (isListPublic(listId) && isValidPublicReservationCreate());
      allow read: if isListOwner(listId) || isListPublic(listId);
      allow update, delete: if isListOwner(listId);
    }

    match /lists/{listId}/stories/{storyId} {
      allow create: if isListOwner(listId)
        && isValidStoryCreate(listId);
      allow read: if isListOwner(listId) || isListPublic(listId);
      allow update, delete: if isListOwner(listId);
    }

    match /lists/{listId}/wheelEntries/{entryId} {
      allow create: if isListOwner(listId)
        && isValidWheelEntryCreate(listId);
      allow read: if isListOwner(listId) || isListPublic(listId);
      allow update, delete: if isListOwner(listId);
    }

    match /slugClaims/{slug} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.slug == slug;
      allow update, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // Visibility passwords are managed only by trusted server routes.
    match /listAccessSecrets/{listId} {
      allow read, write: if false;
    }

    match /subscriptions/{userId} {
      allow create, read, update, delete: if isUser(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}


